<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Avoid backing up auth-related prefs; FCM token is re-synced after install. -->
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
