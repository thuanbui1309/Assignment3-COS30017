<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Car title text (used across all activities) -->
    <style name="CarTitleStyle">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?colorOnSurface</item>
    </style>

    <!-- Credit/balance display text -->
    <style name="CreditTextStyle">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/credit_positive</item>
    </style>

    <!-- Secondary info text (model, km) -->
    <style name="SecondaryInfoStyle">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Cost highlight text -->
    <style name="CostHighlightStyle">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/accent</item>
    </style>

    <!-- Section title style -->
    <style name="SectionTitleStyle">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?colorOnSurface</item>
    </style>

    <!-- Spec chip text -->
    <style name="SpecChipLabelStyle">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="SpecChipValueStyle">
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?colorOnSurface</item>
    </style>

    <!-- Circular shape for ShapeableImageView avatars -->
    <style name="CircleShapeOverlay" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Rounded rectangle for chat images -->
    <style name="RoundedRectOverlay" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <!-- Filter chip style — accent bg when checked, outline when unchecked -->
    <style name="Widget.CarRental.Chip.Choice" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/chip_bg_color</item>
        <item name="android:textColor">@color/chip_text_color</item>
        <item name="chipStrokeColor">@color/divider</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>

    <!-- Input fields — fixes white border on focus caused by colorPrimary=#FFF -->
    <style name="Widget.CarRental.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/text_input_stroke</item>
        <item name="hintTextColor">@color/text_input_hint</item>
    </style>

    <style name="Widget.CarRental.TextInputLayout.ExposedDropdownMenu" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxStrokeColor">@color/text_input_stroke</item>
        <item name="hintTextColor">@color/text_input_hint</item>
    </style>

    <style name="Widget.CarRental.Button.OutlinedAccent" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/accent</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/accent</item>
        <item name="backgroundTint">@color/white</item>
        <item name="iconTint">@color/accent</item>
    </style>

</resources>
