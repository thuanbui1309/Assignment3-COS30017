<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?android:colorBackground">

    <!-- Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:background="@color/primary"
            app:titleTextColor="?colorOnPrimary"
            app:title="@string/nav_home" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="56dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Search + Sort Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_md"
                android:paddingTop="@dimen/spacing_md"
                android:paddingBottom="@dimen/spacing_sm">

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:hint="@string/search_hint"
                    android:inputType="text"
                    android:textSize="14sp"
                    android:paddingStart="@dimen/spacing_lg"
                    android:paddingEnd="@dimen/spacing_md"
                    android:drawableStart="@drawable/ic_search"
                    android:drawablePadding="@dimen/spacing_sm"
                    android:background="@drawable/bg_search_bar"
                    android:textColor="?colorOnSurface"
                    android:textColorHint="@color/text_secondary" />

                <ImageButton
                    android:id="@+id/btn_sort"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_sort"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/cd_sort"
                    android:scaleType="centerInside"
                    android:layout_marginStart="@dimen/spacing_sm" />

            </LinearLayout>

            <!-- Filter chips: marketplace scope, favourites, open map -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg"
                android:paddingBottom="@dimen/spacing_sm">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleLine="true"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/chip_all"
                        android:textSize="13sp"
                        android:checked="true"
                        style="@style/Widget.CarRental.Chip.Choice" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/filter_by_location"
                        android:textSize="13sp"
                        android:checkable="false"
                        app:chipIcon="@drawable/ic_map"
                        app:chipIconSize="16dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_my_cars"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/chip_my_cars"
                        android:textSize="13sp"
                        style="@style/Widget.CarRental.Chip.Choice" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_favourites"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/chip_favourites"
                        android:textSize="13sp"
                        app:chipIcon="@drawable/ic_favorite"
                        app:chipIconSize="16dp"
                        style="@style/Widget.CarRental.Chip.Choice" />

                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <!-- Credit Badge Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_marginEnd="@dimen/spacing_lg"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="?colorSurface"
                app:strokeColor="@color/accent"
                app:strokeWidth="1.5dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:id="@+id/tv_credit_balance"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/accent"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginStart="@dimen/spacing_sm" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_wallet"
                        app:tint="@color/accent"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:contentDescription="@string/cd_car_image" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section Title -->
            <TextView
                android:id="@+id/tv_section_title"
                style="@style/SectionTitleStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_all"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <!-- Car Grid (RecyclerView) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_cars"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                android:paddingStart="@dimen/spacing_sm"
                android:paddingEnd="@dimen/spacing_sm" />

            <!-- No Cars Message -->
            <TextView
                android:id="@+id/tv_no_cars"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_cars"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:padding="@dimen/spacing_xl"
                android:visibility="gone" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="?colorSurface"
        app:itemIconTint="@color/bottom_nav_item"
        app:itemTextColor="@color/bottom_nav_item"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
