<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="@dimen/spacing_sm"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider"
    app:cardBackgroundColor="?colorSurface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/iv_fav_car"
            android:layout_width="match_parent"
            android:layout_height="@dimen/fav_thumbnail_height"
            android:scaleType="fitCenter"
            android:background="@drawable/bg_car_card"
            android:padding="@dimen/spacing_xs"
            app:layout_constraintTop_toTopOf="parent"
            android:contentDescription="@string/cd_car_image" />

        <ImageButton
            android:id="@+id/btn_remove_fav"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_favorite"
            app:tint="@color/favourite_heart"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_toggle_favourite"
            android:scaleType="centerInside"
            android:layout_margin="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_fav_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="?colorOnSurface"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center"
            android:paddingStart="@dimen/spacing_xs"
            android:paddingEnd="@dimen/spacing_xs"
            android:paddingTop="@dimen/spacing_xs"
            android:paddingBottom="@dimen/spacing_xs"
            app:layout_constraintTop_toBottomOf="@id/iv_fav_car" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
