<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?android:colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:background="@color/primary"
            app:titleTextColor="?colorOnPrimary"
            app:title="@string/messages_title"
            app:navigationIcon="@drawable/ic_arrow_back" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Search Bar -->
        <EditText
            android:id="@+id/et_search_user"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="@string/search_users_hint"
            android:inputType="text"
            android:textSize="14sp"
            android:paddingStart="@dimen/spacing_lg"
            android:paddingEnd="@dimen/spacing_md"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="@dimen/spacing_sm"
            android:background="@drawable/bg_search_bar"
            android:textColor="?colorOnSurface"
            android:textColorHint="@color/text_secondary"
            android:layout_margin="@dimen/spacing_md" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Conversations List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_conversations"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="@dimen/spacing_md" />

            <!-- Search Results -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_search_results"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="@dimen/spacing_md"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_no_conversations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/no_conversations"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:gravity="center"
                android:padding="@dimen/spacing_xl"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
