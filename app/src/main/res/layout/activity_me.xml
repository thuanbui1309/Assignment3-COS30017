<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:colorBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:background="@color/primary"
        app:titleTextColor="?colorOnPrimary"
        app:title="@string/nav_me"
        android:elevation="4dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xl"
            android:gravity="center_horizontal">

            <!-- Avatar -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="@dimen/spacing_xl">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    app:shapeAppearanceOverlay="@style/CircleShapeOverlay" />

                <TextView
                    android:id="@+id/tv_avatar_initials"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_avatar_circle" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="?colorOnSurface"
                android:layout_marginTop="@dimen/spacing_md" />

            <TextView
                android:id="@+id/tv_user_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="@dimen/spacing_xs" />

            <!-- Credits Balance -->
            <TextView
                android:id="@+id/tv_credits_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/credits_balance_label"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="@dimen/spacing_xl" />

            <TextView
                android:id="@+id/tv_credits_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/zero"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/credit_positive"
                android:layout_marginTop="@dimen/spacing_xs" />

            <!-- Top Up Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_top_up"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/top_up_credits"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:backgroundTint="@color/accent"
                android:layout_marginTop="@dimen/spacing_md"
                app:cornerRadius="@dimen/card_corner_radius" />

            <!-- Logout Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/logout"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/error"
                android:textColor="@color/error"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cornerRadius="@dimen/card_corner_radius" />

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?colorSurface"
        app:itemIconTint="@color/bottom_nav_item"
        app:itemTextColor="@color/bottom_nav_item"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled" />

</LinearLayout>

<FrameLayout
    android:id="@+id/loading_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000"
    android:visibility="gone"
    android:clickable="true"
    android:focusable="true">
    <ProgressBar
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/white" />
</FrameLayout>

</FrameLayout>
